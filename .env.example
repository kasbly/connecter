# Database credentials
DB_HOST=localhost
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# Connector API key (shared with Kasbly)
CONNECTOR_API_KEY=kc_change_me_to_a_secure_key

# Optional: Config file path (default: ./connector.config.yml)
# CONFIG_PATH=./connector.config.yml

# Optional: Port override for Docker
# CONNECTOR_PORT=4000
